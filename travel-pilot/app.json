{
  "expo": {
    "name": "Travel-Pilot",
    "slug": "travel-pilot-v2",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon_v3.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/icon_v3.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.travelpilot.app",
      "permissions": [
        "INTERNET"
      ],
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon_v3.png",
        "backgroundColor": "#000000"
      }
    },
    "extra": {
      "eas": {
        "projectId": "71acd23d-946c-4b17-8637-2e7eae12016f"
      }
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "enableJetifier": true,
            "gradleCommand": "assembleRelease",
            "extraParams": {
              "org.gradle.jvmargs": "-Xmx3g -XX:MaxMetaspaceSize=512m -XX:+HeapDumpOnOutOfMemoryError -Dfile.encoding=UTF-8"
            }
          }
        }
      ]
    ],
    "owner": "richardgm2026"
  }
}
